{
  "name": "ehentai-helper",
  "displayName": "E-Hentai Helper",
  "version": "1.0.0",
  "description": "ehentai helper",
  "author": "ocis",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "test": "esbuild tests/download-state.test.ts --bundle --platform=node --format=cjs --outfile=test-results/download-state.test.cjs && node --test test-results/download-state.test.cjs",
    "package": "plasmo package",
    "check:indexes": "node scripts/check-download-indexes.mjs",
    "release": "node scripts/release.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource/roboto-mono": "^5.2.9",
    "@number-flow/react": "^0.6.0",
    "@tanstack/react-virtual": "^3.14.5",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.29.0",
    "lucide-react": "^1.21.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "0.18.20",
    "eslint": "8.53.0",
    "eslint-config-airbnb-typescript": "17.1.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "postcss": "^8.5.3",
    "prettier": "3.2.4",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "3",
    "typescript": "5.3.3"
  },
  "manifest": {
    "default_locale": "en",
    "host_permissions": [
      "https://*/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
    },
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    },
    "permissions": [
      "activeTab",
      "downloads",
      "offscreen",
      "scripting",
      "storage",
      "tabs"
    ]
  }
}
